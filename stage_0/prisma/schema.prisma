generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

//USER MODEL
model User {
  id        String   @id @default(uuid())
  name      String   @unique
  email     String   @unique
  password  String
  boards    Board[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

